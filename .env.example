# Database (SQLite para dev, PostgreSQL para prod)
DATABASE_URL=sqlite:///./oem_ml.db

# Mercado Livre OAuth — obtenha em https://developers.mercadolivre.com.br/
ML_APP_ID=
ML_CLIENT_SECRET=
ML_REDIRECT_URI=http://localhost:8000/auth/ml/callback

# Mercado Livre API
ML_API_BASE_URL=https://api.mercadolibre.com
ML_AUTH_URL=https://auth.mercadolivre.com.br/authorization
ML_SITE_ID=MLB

# Chave de criptografia para tokens (gere com: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
ENCRYPTION_KEY=
