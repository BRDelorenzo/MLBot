# Exemplo de nginx como reverse proxy + servidor estático para o frontend.
# - /static e /, index.html: servidos direto do disco (sem passar pelo FastAPI)
# - restante: proxy para o app uvicorn/gunicorn
# Meta: FastAPI não ver request de estáticos; frontend HTML idem (M4/B2).

upstream mlbot_backend {
    server 127.0.0.1:8000;
    keepalive 16;
}

server {
    listen 443 ssl http2;
    server_name app.meudominio.com;

    ssl_certificate     /etc/letsencrypt/live/app.meudominio.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/app.meudominio.com/privkey.pem;

    client_max_body_size 110m;   # compatível com KB_MAX_PDF_SIZE_MB=100
    gzip on;
    gzip_types text/css application/javascript application/json image/svg+xml;

    root /opt/mlbot/app;

    # Frontend SPA
    location = / {
        try_files /templates/index.html =404;
        add_header Cache-Control "no-cache";
    }

    # Estáticos com cache agressivo
    location /static/ {
        alias /opt/mlbot/app/static/;
        expires 7d;
        add_header Cache-Control "public, max-age=604800, immutable";
    }

    # API e tudo mais → FastAPI
    location / {
        proxy_pass http://mlbot_backend;
        proxy_http_version 1.1;
        proxy_set_header Host              $host;
        proxy_set_header X-Real-IP         $remote_addr;
        proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Request-ID      $request_id;
        proxy_read_timeout 60s;
    }
}
